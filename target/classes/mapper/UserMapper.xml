<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.lostfound.mapper.UserMapper">
    <resultMap id="UserMap" type="User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="salt" column="salt"/>
        <result property="role" column="role"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="User">
        INSERT INTO user (id, username, password_hash, salt, role, created_at)
        VALUES (#{id}, #{username}, #{passwordHash}, #{salt}, #{role}, #{createdAt})
    </insert>

    <select id="findByUsername" resultMap="UserMap">
        SELECT id, username, password_hash, salt, role, created_at
        FROM user
        WHERE username = #{username}
    </select>

    <update id="updatePassword">
        UPDATE user
        SET password_hash = #{passwordHash},
            salt = #{salt}
        WHERE id = #{id}
    </update>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM user
    </select>
</mapper>
